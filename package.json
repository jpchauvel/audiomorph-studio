{
  "name": "audiomorph-studio",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "workspaces": ["apps/desktop", "apps/web", "packages/*"],
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.base.json",
    "test:ts": "vitest run --reporter=junit --outputFile=.test-results/vitest.xml",
    "test:py": "cd apps/sidecar && python3 -m pytest",
    "test": "pnpm test:ts && pnpm test:py"
  }
}
